{
  "name": "rescue-wings-server",
  "version": "1.0.0",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build:bin": "set PKG_CACHE_PATH=../.pkg-cache&& pkg . --targets node18-win-x64 --output ../dist/backend/rescue-wings-server.exe"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.18.0",
    "socket.io": "^4.6.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "**/*.js"
    ],
    "assets": [
      "config/runtime-config.json"
    ]
  }
